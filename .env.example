# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/shantikunj

# JWT / session secret
JWT_SECRET=replace_with_strong_secret
SESSION_SECRET=replace_with_different_strong_secret

# Server port and allowed CORS origins (comma separated)
PORT=5000
CORS_ORIGINS=http://localhost:5173

# Frontend base URL for links in email flows
FRONTEND_URL=http://localhost:5173

# Outgoing email account (used by mailer and follow-up job)
EMAIL_USER=you@example.com
EMAIL_PASS=app_password_or_smtp_password
# Optional: assistance contact shown in follow-up mails
SUPPORT_CONTACT_EMAIL=you@example.com

# Optional Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# Optional: comma-separated languages for translation invite logic.
# Leave empty for all languages, or set to all explicitly.
TRANSLATION_INVITE_LANGUAGES=

# Optional: path to Excel workbook for translation/audio event logs.
# Relative paths are resolved from the server folder.
EXCEL_AUDIT_PATH=./exports/workflow-audit.xlsx
